APP_NAME=ApuGuard AI
APP_VERSION=0.1.0
APP_ENV=development

POSTGRES_DB=apuguard
POSTGRES_USER=apuguard_user
POSTGRES_PASSWORD=apuguard_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

JWT_SECRET_KEY=replace_with_a_secure_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

AI_PROVIDER=local
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=60